---
interface Props {
  imageSrc?: string;
  imageAlt?: string;
  greeting?: string;
  message?: string;
  ctaText?: string;
  ctaHref?: string;
}

const {
  imageSrc = '/mascot.png',
  imageAlt = 'Silver Valley Mascot',
  greeting = 'Welcome to Silver Valley!',
  message = 'Discover our exquisite collection of handcrafted silver jewelry!',
  ctaText = 'Shop Now →',
  ctaHref = '#collections',
} = Astro.props;
---

<div
  id="mascot"
  class="mascot-container"
>
  <div id="mascot-character" class="mascot-character">
    <img src={imageSrc} alt={imageAlt} />
  </div>
  <div id="mascot-tooltip" class="mascot-tooltip">
    <div class="mascot-tooltip-content">
      <p class="mascot-greeting">{greeting}</p>
      <p class="mascot-message">{message}</p>
      <a href={ctaHref} class="mascot-cta">{ctaText}</a>
    </div>
    <div id="tooltip-arrow" class="tooltip-arrow">
      <div class="tooltip-arrow-inner"></div>
    </div>
  </div>
</div>

<style>
  .mascot-container {
    position: fixed;
    bottom: 1.25rem;
    right: 1.25rem;
    z-index: 9999;
    width: 150px;
    height: 150px;
    cursor: pointer;
    animation: mascotEnter 0.2s ease-out 0s forwards;
    opacity: 0;
    visibility: hidden;
  }

  .mascot-character {
    width: 100%;
    height: 100%;
    position: relative;
    animation: mascotCycle 20s ease-in-out infinite;
    animation-delay: 2s;
  }

  .mascot-character img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    filter: drop-shadow(0 4px 6px rgba(0, 0, 0, 0.1));
  }

  .mascot-tooltip {
    position: absolute;
    bottom: 100%;
    right: 0;
    margin-bottom: 1rem;
    border: 2px solid #36848E;
    border-radius: 1rem;
    padding: 1rem;
    min-width: 220px;
    max-width: 280px;
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
    opacity: 0;
    visibility: hidden;
    background: white;
    transform: translateY(0.625rem);
    transition: all 0.3s ease-out;
    backdrop-filter: blur(4px);
  }

  .mascot-container:hover .mascot-tooltip {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .mascot-container:hover .mascot-character {
    animation: mascotJump 0.6s ease-in-out infinite !important;
  }

  .mascot-tooltip-content {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .mascot-greeting {
    font-size: 1rem;
    font-weight: 700;
    color: #111827;
    margin: 0;
    text-align: center;
  }

  .mascot-message {
    font-size: 0.875rem;
    color: #4B5563;
    margin: 0;
    text-align: center;
    line-height: 1.625;
  }

  .mascot-cta {
    display: inline-block;
    text-align: center;
    padding: 0.5rem 1rem;
    background: linear-gradient(to bottom right, #36848E, #2D6E76);
    color: white;
    text-decoration: none;
    border-radius: 0.5rem;
    font-size: 0.875rem;
    font-weight: 600;
    margin-top: 0.25rem;
    transition: all 0.3s;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
  }

  .mascot-cta:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
  }

  .tooltip-arrow {
    position: absolute;
    bottom: -0.625rem;
    right: 2rem;
    width: 0;
    height: 0;
    border-left: 10px solid transparent;
    border-right: 10px solid transparent;
    border-top: 10px solid #36848E;
  }

  .tooltip-arrow-inner {
    position: absolute;
    bottom: 2px;
    left: -8px;
    width: 0;
    height: 0;
    border-left: 8px solid transparent;
    border-right: 8px solid transparent;
    border-top: 8px solid rgba(255, 255, 255, 0.98);
  }

  @media (max-width: 768px) {
    .mascot-container {
      width: 120px !important;
      height: 120px !important;
      bottom: 0.9375rem !important;
      right: 0.9375rem !important;
    }

    .mascot-tooltip {
      min-width: 200px !important;
      max-width: 250px !important;
      padding: 0.75rem !important;
    }
  }
</style>
